{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx", // ✅ IMPORTANT: Pour ne pas importer React

    /* Linting - Désactivez temporairement */
    "noUnusedLocals": false, // ← Désactivé temporairement
    "noUnusedParameters": false, // ← Désactivé temporairement
    "noFallthroughCasesInSwitch": true,
    "strict": false // ← Désactive le mode strict temporairement
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
