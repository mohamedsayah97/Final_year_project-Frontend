{
  "name": "frontend_project",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit --skipLibCheck && vite build",
    "build:force": "vite build",
    "build:ci": "vite build --emptyOutDir",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 100",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:strict": "eslint . --ext ts,tsx --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:staged": "vitest run --passWithNoTests --changedSince=HEAD",
    "test:ci": "vitest run --coverage --silent || true",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "snyk:test": "snyk test --severity-threshold=high",
    "snyk:monitor": "snyk monitor",
    "snyk:fix": "snyk wizard",
    "security": "npm audit && npm run snyk:test",
    "security:fix": "npm audit fix && npm run snyk:fix",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "typecheck:ci": "tsc --noEmit --skipLibCheck || true",
    "pm2:start": "npm run build:force && pm2 start \"npx serve -s dist -l 5173\" --name react-app",
    "pm2:stop": "pm2 stop react-app",
    "pm2:restart": "pm2 restart react-app",
    "pm2:delete": "pm2 delete react-app",
    "pm2:logs": "pm2 logs react-app"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.2",
    "axios": "^1.15.2",
    "chart.js": "^4.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "snyk": "^1.1305.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
